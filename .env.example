# ============================================
# MEDIPREDICT AI - Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Flask
SECRET_KEY=your-super-secret-key-change-this-in-production
FLASK_ENV=production
DEBUG=False

# Database (PostgreSQL for production, SQLite for local)
DATABASE_URL=postgresql://user:password@host:5432/medipredict_db
# For local dev: DATABASE_URL=sqlite:///mediai_users.db

# Email (Gmail SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=Medipredict AI <your-email@gmail.com>

# Admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=AdminSecurePass123

# Railway sets PORT automatically
PORT=5000
